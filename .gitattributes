# Auto detect text files and normalize line endings to LF (matching upstream)
* text=auto eol=lf

# Explicitly declare text files
*.cs text diff
*.csproj text diff
*.sln text diff
*.config text diff
*.settings text diff
*.resx text diff
*.Designer.cs text diff
*.md text diff
*.txt text diff
*.xml text diff
*.json text diff

# Denote all files that are truly binary and should not be modified
# Note: LICENSE uses -text to bypass Git's auto-normalization (see git-line-endings-guide.md)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
*.ttf binary
*.otf binary
*.dds binary
*.d3dtx binary
*.ttarch binary
*.ttarch2 binary
*.obb binary
*.lua binary
*.lenc binary
LICENSE -text
